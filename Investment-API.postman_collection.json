{
  "info": {
    "_postman_id": "7c6324d1-21e1-4a4a-83b8-16e9b2342d71",
    "name": "Investment ROI Referral API",
    "description": "Postman collection for testing auth, investments, dashboard, referral tree, and ROI calculation APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "userAEmail",
      "value": "usera{{$timestamp}}@test.com"
    },
    {
      "key": "userBEmail",
      "value": "userb{{$timestamp}}@test.com"
    },
    {
      "key": "password",
      "value": "Password123"
    },
    {
      "key": "userAToken",
      "value": ""
    },
    {
      "key": "userBToken",
      "value": ""
    },
    {
      "key": "userAReferralCode",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"User A\",\n  \"email\": \"{{userAEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('User A registered', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('userAToken', json.accessToken);",
              "pm.collectionVariables.set('userAReferralCode', json.user.referralCode);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Register User B With User A Referral Code",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"User B\",\n  \"email\": \"{{userBEmail}}\",\n  \"password\": \"{{password}}\",\n  \"referralCode\": \"{{userAReferralCode}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('User B registered', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('userBToken', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Login User B",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userBEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('User B logged in', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('userBToken', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. Create Investment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{userBToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/investments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "investments"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 1000,\n  \"plan\": \"starter\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Investment created', function () { pm.response.to.have.status(201); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. User B Dashboard",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userBToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/dashboard",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "dashboard"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Dashboard fetched', function () { pm.response.to.have.status(200); });",
              "pm.test('Dashboard has totals', function () { pm.expect(pm.response.json()).to.have.property('totals'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. User A Dashboard - Level Income",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userAToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/dashboard",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "dashboard"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('User A dashboard fetched', function () { pm.response.to.have.status(200); });",
              "pm.test('User A has level income total', function () { pm.expect(pm.response.json().totals.totalLevelIncome).to.be.a('number'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7. User A Referral Tree",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userAToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/referrals/tree",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "referrals",
            "tree"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Referral tree fetched', function () { pm.response.to.have.status(200); });",
              "pm.test('Referral tree is an array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
